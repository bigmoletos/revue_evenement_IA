# Copier dans .env et remplir les valeurs
# Ou configurer comme secrets GitHub Actions

# Email SMTP (ex: Gmail avec mot de passe d'application)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=[votre-email]@gmail.com
SMTP_PASSWORD=[mot-de-passe-application]
MAIL_TO=[destinataire]@gmail.com

# GitHub (publication GitHub Pages)
GITHUB_TOKEN=[votre-token-github]
GITHUB_REPOSITORY=[owner/repo]
